{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "https://localhost:7074",
    "Key": "x);}F:1|k/hXEWH*o?Z*a*WeuNJW/O1wSC*8b8v)|$3",
    "Audience": "localhost:1234",
    "ExpireMinutes": 30
  },
  "ReverseProxy": {
    "Routes": {
      "coreRoute": {
        "ClusterId": "coreCluster",
        "Match": {
          "Path": "/api/core/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/core" }
        ]
      },
      "notiRoute": {
        "ClusterId": "notiCluster",
        "AuthorizationPolicy": "authPolicy",
        "Match": {
          "Path": "/api/noti/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/noti" }
        ]
      },
      "fileRoute": {
        "ClusterId": "fileCluster",
        "AuthorizationPolicy": "authPolicy",
        "Match": {
          "Path": "/api/file/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/file" }
        ]
      },
      "realtimeRoute": {
        "ClusterId": "realtimeCluster",
        "AuthorizationPolicy": "authPolicy",
        "Match": {
          "Path": "/hub/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/hub" }
        ]
      }
    },
    "Clusters": {
      "coreCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5051/"
          }
        }
      },
      "notiCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5107/"
          }
        }
      },
      "fileCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5139/"
          }
        }
      },
      "realtimeCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5136/"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
